C4Dynamic
  title Northstar Commerce — Place an Order

  Container(storefront, "Web Storefront", "TypeScript", "Customer-facing shopping experience")
  Container(api, "Commerce API", "Node.js", "Coordinates checkout and order rules")
  Container(worker, "Fulfillment Worker", "Node.js", "Starts asynchronous fulfillment")
  ContainerDb(database, "Commerce Database", "PostgreSQL", "Stores orders and payment records")
  ContainerQueue(events, "Event Stream", "AMQP", "Distributes durable commerce events")
  Container_Ext(inventory, "Inventory Service", "Warehouse platform", "Owns available-to-promise stock")
  System_Ext(payment, "Payment Service", "Authorizes and settles payments")
  System_Ext(carrier, "Carrier Network", "Creates and tracks shipments")

  RelIndex(1, storefront, api, "Submits checkout", "HTTPS/JSON")
  RelIndex(2, api, inventory, "Reserves requested items", "HTTPS/JSON")
  RelIndex(3, inventory, api, "Confirms the reservation", "JSON")
  RelIndex(4, api, payment, "Authorizes the order total", "HTTPS/JSON")
  RelIndex(5, payment, api, "Returns the authorization", "JSON")
  RelIndex(6, api, database, "Commits the confirmed order", "TLS/SQL")
  RelIndex(7, api, events, "Publishes OrderConfirmed", "AMQP")
  RelIndex(8, api, storefront, "Returns order confirmation", "HTTPS/JSON")
  RelIndex(9, events, worker, "Delivers OrderConfirmed", "AMQP")
  RelIndex(10, worker, carrier, "Creates the shipment", "HTTPS/JSON")
