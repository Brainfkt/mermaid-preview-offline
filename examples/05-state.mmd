---
title: Order lifecycle and fulfillment
---
stateDiagram-v2
  [*] --> Draft
  Draft --> Validating : submit order
  Draft --> Cancelled : abandon checkout

  state Validating {
    [*] --> CheckInventory
    CheckInventory --> CheckPayment : items reserved
    CheckPayment --> [*] : authorization recorded
  }

  state validationResult <<choice>>
  Validating --> validationResult
  validationResult --> Confirmed : all checks pass
  validationResult --> Rejected : a check fails

  state Confirmed {
    [*] --> Ready
    state workFork <<fork>>
    Ready --> workFork
    workFork --> PickAndPack
    workFork --> CapturePayment

    state workJoin <<join>>
    PickAndPack --> workJoin : parcel sealed
    CapturePayment --> workJoin : funds captured
    workJoin --> Shipped : hand off to carrier
    Shipped --> [*]
  }

  Confirmed --> Delivered : delivery confirmed
  Confirmed --> ReturnRequested : return opened
  ReturnRequested --> Refunded : parcel received
  Rejected --> Draft : revise order
  Rejected --> Cancelled : stop checkout
  Delivered --> [*]
  Refunded --> [*]
  Cancelled --> [*]

  note right of Validating : Inventory and payment checks are coordinated before confirmation.
  note right of Confirmed : Fulfillment and payment capture run in parallel.
