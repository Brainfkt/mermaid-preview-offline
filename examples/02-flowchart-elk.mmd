---
title: Global commerce service landscape
---
flowchart-elk TB
  shopper[Web and mobile clients]

  subgraph edge [Global edge]
    direction LR
    cdn[Content delivery network]
    gateway[API gateway]
    identity[Identity provider]
    cdn --> gateway
    gateway --> identity
  end

  subgraph platform [Commerce platform]
    direction LR
    subgraph experience [Experience services]
      catalog[Catalog]
      search[Search]
      cart[Cart]
    end
    subgraph transaction [Transaction services]
      orders[Order orchestration]
      inventory[Inventory]
      payments[Payments]
    end
    catalog --> search
    catalog --> cart
    cart ==> orders
    orders --> inventory
    orders --> payments
  end

  subgraph data [Data and integrations]
    direction LR
    primary[(Operational database)]
    events{{Event stream}}
    warehouse[(Analytics warehouse)]
    carriers[Carrier network]
  end

  shopper --> cdn
  gateway --> catalog
  gateway --> search
  gateway --> cart
  gateway --> orders
  orders --> primary
  orders ==> events
  events --> warehouse
  events -.-> carriers

  classDef entry fill:#e0f2fe,stroke:#0284c7,color:#0c4a6e;
  classDef service fill:#ede9fe,stroke:#7c3aed,color:#2e1065;
  classDef store fill:#dcfce7,stroke:#16a34a,color:#14532d;
  class shopper,cdn,gateway entry;
  class catalog,search,cart,orders,inventory,payments service;
  class primary,events,warehouse store;
