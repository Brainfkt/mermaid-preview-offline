    type: service
    docRef: ADR012
  }

  element api_contract {
    type: contract
    docRef: OPENAPI01
  }

  element acceptance_suite {
    type: test_suite
    docRef: TESTPLAN01
  }

  element load_suite {
    type: test_suite
    docRef: PERFPLAN01
  }

  checkout - contains -> checkout_api
  accessible_checkout - refines -> checkout
  order_service - satisfies -> checkout
  api_contract - satisfies -> checkout_api
