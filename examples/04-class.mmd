---
title: Order domain model
---
classDiagram
  direction LR

  class Order {
    <<aggregate>>
    +UUID id
    +OrderStatus status
    +Money total
    +addItem(product, quantity)
    +confirm(payment) OrderConfirmed
    +cancel(reason)
  }

  class OrderLine {
    +int quantity
    +Money unitPrice
    +subtotal() Money
  }

  class Product {
    <<entity>>
    +SKU sku
    +String name
    +Money price
    +bool active
  }

  class Customer {
    <<entity>>
    +UUID id
    +Email email
    +placeOrder(cart) Order
  }

  class PaymentMethod {
    <<interface>>
    +authorize(amount) Authorization
    +capture(authorization) Receipt
    +refund(receipt, amount)
  }

  class CardPayment {
    -String token
    +authorize(amount) Authorization
    +capture(authorization) Receipt
  }

  class OrderRepository {
    <<interface>>
    +findById(id) Order
    +save(order)
  }

  class OrderStatus {
    <<enumeration>>
    DRAFT
    CONFIRMED
    FULFILLED
    CANCELLED
  }

  Customer "1" --> "0..*" Order : places
  Order "1" *-- "1..*" OrderLine : owns
  OrderLine "*" --> "1" Product : references
  Order --> OrderStatus : has
  Order ..> PaymentMethod : authorizes through
  PaymentMethod <|.. CardPayment : implements
  OrderRepository ..> Order : persists
  note for Order "Enforces pricing, payment, and lifecycle invariants"
