{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mermaid",
  "scopeName": "source.mermaid",
  "patterns": [
    { "include": "#directives" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#diagramKeywords" },
    { "include": "#arrows" },
    { "include": "#numbers" }
  ],
  "repository": {
    "directives": {
      "patterns": [
        {
          "name": "meta.directive.mermaid",
          "begin": "%%\\{",
          "end": "\\}%%"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.percentage.mermaid",
          "match": "%%.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mermaid",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single.mermaid",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "diagramKeywords": {
      "patterns": [
        {
          "name": "keyword.control.mermaid",
          "match": "\\b(flowchart-elk|flowchart|graph|sequenceDiagram|classDiagram|stateDiagram-v2|stateDiagram|erDiagram|journey|gantt|pie|quadrantChart|requirementDiagram|gitGraph|mindmap|timeline|sankey-beta|xychart-beta|block-beta|packet-beta|kanban|architecture-beta|radar-beta|treemap-beta|zenuml|C4Context|C4Container|C4Component|C4Dynamic|C4Deployment|swimlane-beta|eventmodeling|venn-beta|ishikawa-beta|wardley-beta|cynefin-beta|treeView-beta|railroad-beta|railroad-ebnf-beta|railroad-abnf-beta|railroad-peg-beta|info|subgraph|end|participant|actor|activate|deactivate|loop|alt|else|opt|par|and|rect|critical|break|classDef|class|style|linkStyle|click|direction|title|section|accTitle|accDescr)\\b"
        }
      ]
    },
    "arrows": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.mermaid",
          "match": "(-->|---|-\\.->|==>|-->>|->>|--x|--o|<-->|<->|\\|>)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mermaid",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    }
  }
}
